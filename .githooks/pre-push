#!/usr/bin/env python3
"""
Git pre-push hook — jalankan PR gate otomatis sebelum push.
Cegah push branch PR yang tidak lolos gate (label mismatch, scoring gagal, dll).

Install: git config core.hooksPath .githooks
Skip:    git push --no-verify  (atau export SKIP_PR_GATE=1)
"""

import json, os, re, subprocess, sys

SKIP_ENV = "SKIP_PR_GATE"
if os.environ.get(SKIP_ENV):
    sys.exit(0)

# Only check branches matching fix/NNNN-* or feat/NNNN-*
branch = ""
try:
    ref = sys.argv[1] if len(sys.argv) > 1 else ""
    if not ref:
        r = subprocess.run(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True, text=True, timeout=5
        )
        branch = r.stdout.strip() if r.returncode == 0 else ""
    else:
        branch = ref.split("/", 1)[-1].split(":")[-1] if ":" in ref else ref
except Exception:
    sys.exit(0)

m = re.match(r'(fix|feat)/(\d+)', branch)
if not m:
    sys.exit(0)  # skip non-PR branches

prefix = m.group(1)
issue = int(m.group(2))

GATE_SCRIPT = os.path.join(os.path.dirname(__file__), "..", "scripts", "pr_pregate.py")
if not os.path.exists(GATE_SCRIPT):
    GATE_SCRIPT = os.path.join(os.path.dirname(__file__), "..", "..", "scripts", "pr_pregate.py")
if not os.path.exists(GATE_SCRIPT):
    sys.exit(0)

print(f"\n  ╔{'═'*55}╗")
print(f"  ║  PR PRE-SUBMIT GATE (pre-push hook)           ║")
print(f"  ╚{'═'*55}╝")
print(f"  Branch: {branch}")

r = subprocess.run(
    [sys.executable, GATE_SCRIPT, "--issue", str(issue), "--prefix", prefix,
     "--branch", branch, "--json"],
    capture_output=True, text=True, timeout=45
)

try:
    result = json.loads(r.stdout)
    passed = result.get("passed", False)
    fatal = result.get("fatal", False)
except (json.JSONDecodeError, ValueError):
    passed = False
    fatal = True

if r.returncode == 0 and passed:
    print(f"  ✅ Gate PASSED — push allowed\n")
    sys.exit(0)

print(f"  ❌ Gate BLOCKED — push ditolak!")
print(f"     Perbaiki masalah di atas, lalu push ulang.")
print(f"     (atau: SKIP_PR_GATE=1 git push untuk bypass)\n")
sys.exit(1)
